# ===================================
# injection-tool 環境設定
# ===================================

# 管理画面のログイン認証
INJECTION_ADMIN_USERNAME=admin
INJECTION_ADMIN_PASSWORD=your_secure_password_here

# ドメイン別の知識ソース設定（JSON ファイルパス、またはAPI URL）
# MVP版では複数ドメインを配列で管理
INJECTION_DOMAINS_CONFIG=./data/domains.json

# キャッシュの有効期限（秒）
# Amica側がこのTTLを参考にしてローカルキャッシュを管理
INJECTION_DEFAULT_TTL=3600

# 初期ドメイン（初回生成時）
INJECTION_DEFAULT_DOMAIN_ID=default
INJECTION_DEFAULT_DOMAIN_NAME=デフォルト
INJECTION_DEFAULT_DOMAIN_DESCRIPTION=初期ドメイン
INJECTION_DEFAULT_DOMAIN_BASE_SYSTEM_PROMPT=あなたは丁寧で信頼できる案内役です。
INJECTION_DEFAULT_DOMAIN_BASE_CONTEXT=共通ナレッジを活用し、簡潔かつ正確に回答してください。

# 初期ナレッジ（初回生成時）
INJECTION_DEFAULT_KNOWLEDGE_ID=default_knowledge
INJECTION_DEFAULT_KNOWLEDGE_NAME=デフォルトナレッジ
INJECTION_DEFAULT_KNOWLEDGE_DESCRIPTION=初期ナレッジ
INJECTION_DEFAULT_KNOWLEDGE_SYSTEM_PROMPT=ユーザーの意図を汲み取り、必要十分な情報のみを返答してください。
INJECTION_DEFAULT_KNOWLEDGE_CONTEXT=初期コンテキスト
INJECTION_DEFAULT_KNOWLEDGE_PRIORITY=100

# ログレベル
LOG_LEVEL=info

# アプリケーション起動ポート（開発環境）
PORT=4001

# Amica接続元の許可オリジン（CORS対応）
NEXT_PUBLIC_AMICA_ORIGIN=http://localhost:3000

# injection-tool 自身の公開オリジン（外部公開・VPN・リバースプロキシ環境向け）
# 設定するとアセット URL（VRM・背景画像）がこのオリジンの絶対 URL になります
# ローカル開発時は設定不要（リクエストの Host ヘッダーから自動導出）
# 例: NEXT_PUBLIC_INJECTION_TOOL_ORIGIN=https://injection.example.com
# NEXT_PUBLIC_INJECTION_TOOL_ORIGIN=

# Amica設定取得先URL（モデル名取得に利用）
INJECTION_AMICA_URL=http://localhost:3000

# Ollama API URL（/api/show でcontext length取得）
INJECTION_OLLAMA_URL=http://127.0.0.1:11434

# Amicaからモデル名が取得できない場合のフォールバック
INJECTION_FALLBACK_MODEL=pakachan/elyza-llama3-8b

# Style-Bert-VITS2 API URL（モデル一覧取得に利用）
INJECTION_STYLEBERTVITS2_URL=http://127.0.0.1:5000

# Node環境
NODE_ENV=development
